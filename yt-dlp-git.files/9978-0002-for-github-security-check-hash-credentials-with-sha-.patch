From 856a69cfc3f6946e1cf166e84ca5ef7b1bbc67d2 Mon Sep 17 00:00:00 2001
From: Mozi <29089388+pzhlkj6612@users.noreply.github.com>
Date: Thu, 23 May 2024 13:52:35 +0000
Subject: [PATCH 02/12] for github security check: hash credentials with sha-1
 instead of md5

---
 yt_dlp/extractor/sheeta.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/yt_dlp/extractor/sheeta.py b/yt_dlp/extractor/sheeta.py
index 3209b1ecd..b24f25b74 100644
--- a/yt_dlp/extractor/sheeta.py
+++ b/yt_dlp/extractor/sheeta.py
@@ -532,7 +532,7 @@ def _niconico_sns_login(self, redirect_url, refresh_url):
         if not mail_tel:
             return
 
-        cache_key = hashlib.md5(f'{self._DOMAIN}:{mail_tel}:{password}'.encode()).hexdigest()
+        cache_key = hashlib.sha1(f'{self._DOMAIN}:{mail_tel}:{password}'.encode()).hexdigest()
         self._auth_info = {'cache_key': cache_key}
         cache_name = 'niconico_sns'
 
@@ -640,7 +640,7 @@ def _auth0_login(self):
         if not username:
             return
 
-        cache_key = hashlib.md5(f'{self._DOMAIN}:{username}:{password}'.encode()).hexdigest()
+        cache_key = hashlib.sha1(f'{self._DOMAIN}:{username}:{password}'.encode()).hexdigest()
         cache_name = 'refresh'
         self._auth_info = {
             'cache_key': cache_key,
-- 
